# Frontend — ตัวแปรสภาพแวดล้อม (ตัวอย่าง)
# คัดลอกเป็น .env.local แล้วปรับตามเครื่อง

# ว่าง = ใช้ Vite proxy (/api → http://127.0.0.1:8000) ตอน npm run dev
# VITE_API_BASE_URL=

# Production / ทดสอบข้าม origin
# VITE_API_BASE_URL=https://api.example.com

# Auth / Session (เตรียมรองรับ Redis server-side sessions)
# bearer = JWT ใน localStorage (ค่าเริ่มต้น — ใช้งานปัจจุบัน)
# cookie = HttpOnly cookie จาก API (เมื่อ Backend รองรับคุกกี้เซสชัน)
# VITE_AUTH_TRANSPORT=bearer

# ตั้ง true เมื่อ Backend เปิด REDIS_SESSIONS_ENABLED — FE จะเรียก POST /auth/logout ก่อนล้าง local
# VITE_SERVER_SESSIONS=false
