# .env.example — CONTROL-Z Docker Compose environment template
#
# Usage:
#   cp .env.example .env
#   chmod 600 .env          # restrict read access to owner only
#   chown root:root .env    # on VPS: owned by root
#   # Edit .env with your actual values before running docker compose up
#
# NEVER commit .env to git. It is listed in .gitignore.

# ─── Database ────────────────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=
MYSQL_DATABASE=control_z
MYSQL_USER=user
MYSQL_PASSWORD=

# ─── Backend ─────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=
PASSWORD_RESET_SECRET_KEY=
DEBUG=false
# Comma-separated list of allowed CORS origins
CORS_ORIGINS=https://yourdomain.com
FRONTEND_BASE_URL=https://yourdomain.com

# ─── Mail ────────────────────────────────────────────────────────────────────
# Set MAIL_ENABLED=true and fill credentials for production email sending.
# Gmail: create an App Password (requires 2FA enabled on the account).
MAIL_ENABLED=false
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_STARTTLS=true
MAIL_SSL_TLS=false
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=
MAIL_FROM_NAME=CONTROL-Z

# ─── Redis ───────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(24))"
REDIS_PASSWORD=
# เปิด cache + server-side sessions เมื่อมี Redis (ค่าเริ่มต้นใน compose)
REDIS_CACHE_ENABLED=true
REDIS_SESSIONS_ENABLED=true
# Frontend build (compose.dev) — เรียก POST /auth/logout ก่อนล้าง local
VITE_SERVER_SESSIONS=true

# ─── Backup ──────────────────────────────────────────────────────────────────
# Used by scripts/backup.sh and scripts/rclone-sync.sh
BACKUP_DIR=/opt/controlz/storage/backup
# rclone remote name + path (configure remote via: rclone config)
# Examples:
#   s3:my-bucket/controlz-backup
#   b2:my-bucket/controlz-backup
#   gdrive:controlz-backup
RCLONE_REMOTE=remote:controlz-backup

# ─── Domain ──────────────────────────────────────────────────────────────────
# Used in nginx/conf.d/default.conf — replace with actual domain
DOMAIN=yourdomain.com

# ─── Deploy (compose.prod.yaml + scripts/deploy.sh) ──────────────────────────
# GitHub org/user that owns the GHCR container packages
GHCR_ORG=your-org
# Version tag being deployed — update per release (e.g. v1.2.0)
IMAGE_TAG=v1.0.0
