DATABASE_URL=mysql+pymysql://user:mysql%40%231234@127.0.0.1:3306/control_z
# สำหรับ EF bridge + หน้ากรอกข้อมูล v2: ใช้ control_z_v2 หลังรัน docs/database-seed.sql
# DATABASE_URL=mysql+pymysql://root:root@127.0.0.1:3306/control_z_v2
JWT_SECRET_KEY=replace-with-long-random-secret
DEBUG=false
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Password reset (JWT แยกจาก access token)
PASSWORD_RESET_SECRET_KEY=replace-with-long-random-reset-secret
PASSWORD_RESET_EXPIRE_MINUTES=10
FRONTEND_BASE_URL=http://localhost:5173

# SMTP — ตั้ง MAIL_ENABLED=true เมื่อพร้อมส่งอีเมลจริง (production)
# Dev: ปล่อย false แล้วดู reset link ใน log ของ Backend
MAIL_ENABLED=false
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_STARTTLS=true
MAIL_SSL_TLS=false
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=
MAIL_FROM_NAME=CONTROL-Z

MAIL_FROM_NAME=CONTROL-Z

# Redis (optional) — ว่าง = ไม่ใช้ Redis พฤติกรรมเดิมทั้งหมด
# REDIS_URL=redis://127.0.0.1:6379/0
# REDIS_KEY_PREFIX=controlz
# REDIS_CACHE_ENABLED=true
# REDIS_CACHE_DEFAULT_TTL_SECONDS=300
# REDIS_CACHE_EF_TTL_SECONDS=3600
# REDIS_CACHE_CALC_LATEST_TTL_SECONDS=120
# REDIS_SESSIONS_ENABLED=false
# SESSION_TTL_SECONDS=86400
# SESSION_COOKIE_NAME=controlz_session
# SESSION_COOKIE_SECURE=false
# SESSION_COOKIE_SAMESITE=lax

# Gmail production: สมัคร Gmail ใหม่ → เปิด 2FA → App Password → ใส่ MAIL_USERNAME + MAIL_PASSWORD
